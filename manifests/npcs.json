              "effect": "openStore"
            },
            {
              "text": "Not right now.",
              "nextNodeId": "farewell"
            }
          ]
        },
        {
          "id": "quest_offer",
          "text": "The essence rocks near the altars contain rune essence - the raw material for crafting runes. Mine 25 essence, then use them at the air altar to craft air runes. Here's a pickaxe to get you started.",
          "responses": [
            {
              "text": "I'll do it.",
              "nextNodeId": "quest_accepted",
              "effect": "startQuest:rune_mysteries"
