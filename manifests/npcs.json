              "text": "Maybe later.",
              "nextNodeId": "farewell"
            }
          ]
        },
        {
          "id": "quest_accepted",
          "text": "Excellent! The essence rocks are just south of here, near the runecrafting altars. Mine the essence, then use it at the air altar to craft air runes."
        },
        {
          "id": "progress_check",
          "text": "How goes the runecrafting? Have you mined the essence and crafted the air runes?",
          "responses": [
